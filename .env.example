# @sw4p/kit — example env. Copy to .env and fill in your secrets.
# .env is gitignored — never commit real values.

# AP2 mandate signing (HmacSigner reference impl)
# Generate locally with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AP2_SIGNING_KEY=

# x402 payment-verification HMAC (only needed if your server verifies refs locally)
X402_VERIFY_SECRET=

# sw4p backend
SW4P_API_URL=https://api.sw4p.io
SW4P_API_KEY=

# Staging (Phase 2 of evidence plan)
SW4P_STAGING_URL=https://staging.api.sw4p.io
SW4P_STAGING_KEY=

# Testnet smoke (Phase 3) — Base Sepolia → Solana devnet
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
TESTNET_FROM_ADDRESS=
TESTNET_SOLANA_DESTINATION=

# Mainnet canary (Phase 7) — DO NOT ENABLE WITHOUT EXPLICIT APPROVAL
SW4P_MAINNET_CANARY=0
SW4P_MAINNET_URL=https://api.sw4p.io
SW4P_MAINNET_KEY=
SW4P_CANARY_FROM=
SW4P_CANARY_TO=
